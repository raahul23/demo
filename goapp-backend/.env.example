# Server
NODE_ENV=development
PORT=3000

# JWT
JWT_SECRET=change_this_to_a_min_32_char_secret_string
JWT_REFRESH_SECRET=change_this_to_another_min_32_char_secret

# Database
DATABASE_URL=postgresql://goapp:goapp_secret@localhost:5432/goapp

# Redis
REDIS_URL=redis://:goapp_redis_secret@localhost:6379

# Google Maps / Routes
GOOGLE_MAPS_API_KEY=

# Firebase FCM (base64-encoded service account JSON)
FIREBASE_SERVICE_ACCOUNT_B64=

# SMS / OTP (MSG91)
MSG91_AUTH_KEY=
MSG91_TEMPLATE_ID=

# AWS S3 (driver documents)
AWS_S3_BUCKET=goapp-documents
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Dev helpers
OTP_BYPASS=true
# When OTP_BYPASS=true the OTP is always "0000" (dev only — never set in production)
